<?xml version="1.0" encoding="utf-8"?>
<!--
    Android data-extraction rules (API 31+ — used for cloud backup AND device-to-device transfer).
    Excludes the EncryptedSharedPreferences file that stores JWT tokens and the setup token.
    Reference: https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="ks_auth_secure.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="ks_auth_secure.xml" />
    </device-transfer>
</data-extraction-rules>
