# ═══════════════════════════════════════════════════════════════════
# KanoonSaathi Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It's already in .gitignore.
# ═══════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000

# ── PostgreSQL ─────────────────────────────────────────────────────
# Local:   postgresql://postgres:password@localhost:5432/kanoonsaathi
# Railway: get from Railway dashboard → your PostgreSQL service → Connect tab
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── Redis (Upstash) ───────────────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API section
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE

# ── JWT Secrets ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters. Use different values for each!
JWT_SECRET=GENERATE_A_LONG_RANDOM_STRING_HERE_AT_LEAST_64_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=30

ADMIN_JWT_SECRET=GENERATE_ANOTHER_DIFFERENT_LONG_RANDOM_STRING_HERE

# ── Google OAuth ──────────────────────────────────────────────────
# Get from: https://console.cloud.google.com
#   → APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   → Application type: Android (for the app)
# You only need the Client ID here — never put the Client Secret in backend
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── AI: Anthropic (Claude) ────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── AI: OpenAI (fallback — optional in development) ──────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# ── Email (Resend) ────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Free plan: 100 emails/day, 3000/month
RESEND_API_KEY=re_YOUR_KEY_HERE
EMAIL_FROM=noreply@kanoonsaathi.in

# ── Rate Limits (free plan) ───────────────────────────────────────
FREE_MESSAGES_PER_HOUR=30
FREE_TOKENS_PER_DAY=50000

# ── Seed ─────────────────────────────────────────────────────────
# Only needed when running: npm run db:seed
ADMIN_SEED_PASSWORD=choose_a_strong_admin_password_here
